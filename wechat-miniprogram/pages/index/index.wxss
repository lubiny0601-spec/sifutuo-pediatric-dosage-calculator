/* index.wxss */
page {
  background: linear-gradient(180deg, #f8fafc 0%, #eff6ff 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
  color: #0f172a;
}

.container {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
}

/* Animations */
.animated-fade-in {
  animation: fadeIn 0.5s ease-out forwards;
}

.stagger-1 {
  animation-delay: 0.1s;
}

.stagger-2 {
  animation-delay: 0.2s;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Header Section */
.header {
  margin-bottom: 30rpx;
  margin-top: 10rpx;
}

.title-container {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.main-title {
  font-size: 42rpx;
  font-weight: 800;
  letter-spacing: -0.5px;
  color: #0f172a;
}

.badge-mini {
  font-size: 20rpx;
  background: #eff6ff;
  color: #1d4ed8;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-weight: 700;
  border: 1px solid rgba(29, 78, 216, 0.1);
}

.subtitle {
  font-size: 26rpx;
  color: #64748b;
  margin-top: 8rpx;
  line-height: 1.4;
}

/* Card layout */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 10rpx 40rpx rgba(15, 23, 42, 0.04), 0 2rpx 4rpx rgba(15, 23, 42, 0.01);
  border: 1rpx solid rgba(0, 0, 0, 0.03);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

/* Tab selector */
.tab-toggle {
  display: flex;
  background: #f1f5f9;
  padding: 8rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.tab-btn {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #64748b;
  padding: 14rpx 0;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.tab-btn.active {
  background: #ffffff;
  color: #1d4ed8;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* Static info drug panel */
.static-drug-info {
  background: #f8fafc;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.static-drug-info .label {
  font-size: 20rpx;
  font-weight: 700;
  color: #64748b;
  text-transform: uppercase;
  margin-bottom: 4rpx;
}

.static-drug-info .value {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

/* Form groups */
.form-group {
  margin-bottom: 30rpx;
}

.form-label-row {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}

.step-num {
  font-size: 20rpx;
  font-weight: 700;
  color: #ffffff;
  background: #1d4ed8;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #334155;
}

.input-control {
  border: 1rpx solid #cbd5e1;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  background: #ffffff;
  transition: border 0.2s ease;
}

.picker-control {
  border: 1rpx solid #cbd5e1;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  background: #ffffff;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  font-size: 20rpx;
  color: #94a3b8;
}

/* Toggle Switches */
.toggle-switch {
  display: flex;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 6rpx;
}

.switch-btn {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #64748b;
  padding: 12rpx 0;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.switch-btn.active {
  background: #1d4ed8;
  color: #ffffff;
}

/* Cockcroft-Gault Calculator */
.cg-panel {
  border: 1rpx solid rgba(29, 78, 216, 0.12);
  background: #eff6ff;
  border-radius: 18rpx;
  overflow: hidden;
  margin-top: 10rpx;
}

.cg-header {
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(29, 78, 216, 0.05);
}

.cg-title {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #1d4ed8;
}

.cg-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.cg-toggle-indicator {
  font-size: 22rpx;
  font-weight: 600;
  color: #1d4ed8;
}

.cg-body {
  padding: 24rpx;
  border-top: 1rpx solid rgba(29, 78, 216, 0.08);
}

.cg-grid {
  display: flex;
  gap: 16rpx;
}

.cg-field {
  flex: 1;
}

.cg-label {
  font-size: 20rpx;
  font-weight: 700;
  color: #475569;
  margin-bottom: 8rpx;
}

.cg-input {
  border: 1rpx solid rgba(29, 78, 216, 0.2);
  background: #ffffff;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  font-size: 26rpx;
  height: 64rpx;
  box-sizing: border-box;
}

.cg-gender-toggle {
  display: flex;
  background: #e2e8f0;
  padding: 4rpx;
  border-radius: 12rpx;
  height: 64rpx;
  box-sizing: border-box;
}

.gender-btn {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #475569;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
}

.gender-btn.active {
  background: #ffffff;
  color: #1d4ed8;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
}

.scr-input-container {
  display: flex;
  border: 1rpx solid rgba(29, 78, 216, 0.2);
  border-radius: 12rpx;
  background: #ffffff;
  overflow: hidden;
  height: 64rpx;
  box-sizing: border-box;
}

.scr-input {
  flex: 1;
  border: none;
  padding: 12rpx 16rpx;
}

.scr-unit-picker {
  background: #f1f5f9;
  border-left: 1rpx solid rgba(29, 78, 216, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
}

.unit-picker-text {
  font-size: 22rpx;
  color: #475569;
  font-weight: 600;
  line-height: 62rpx;
}

.cg-result-bar {
  margin-top: 20rpx;
  background: rgba(22, 163, 74, 0.08);
  border: 1rpx dashed rgba(22, 163, 74, 0.3);
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #166534;
  font-weight: 600;
  text-align: center;
}

.cg-result-val {
  font-size: 30rpx;
  color: #15803d;
  font-family: Consolas, Monaco, monospace;
}

.cg-calc-btn {
  margin-top: 20rpx;
  background: #1d4ed8;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 12rpx;
  padding: 14rpx 0;
  text-align: center;
  line-height: 1.5;
  box-shadow: 0 4rpx 12rpx rgba(29, 78, 216, 0.15);
}

/* Status Badges */
.status-badge {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
  gap: 8rpx;
}

.status-badge .dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}

.badge-success {
  background: #dcfce7;
  color: #15803d;
  border: 1rpx solid rgba(22, 163, 74, 0.1);
}

.badge-success .dot {
  background: #16a34a;
}

.badge-error {
  background: #fee2e2;
  color: #b91c1c;
  border: 1rpx solid rgba(220, 38, 38, 0.1);
}

.badge-error .dot {
  background: #dc2626;
}

.badge-pending {
  background: #f1f5f9;
  color: #64748b;
  border: 1rpx solid rgba(100, 116, 139, 0.1);
}

.badge-pending .dot {
  background: #64748b;
}

/* Result styles */
.result-grid {
  display: flex;
  gap: 20rpx;
  margin-top: 10rpx;
}

.result-cell {
  flex: 1;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}

.cell-label {
  font-size: 20rpx;
  color: #64748b;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.cell-val {
  font-size: 44rpx;
  font-weight: 800;
  color: #0f172a;
  font-family: Consolas, Monaco, monospace;
}

.cell-val .unit {
  font-size: 24rpx;
  font-weight: 600;
  color: #94a3b8;
  margin-left: 4rpx;
}

.total-dose-display {
  margin-top: 20rpx;
  background: #eff6ff;
  border: 1rpx solid rgba(29, 78, 216, 0.1);
  border-radius: 14rpx;
  padding: 16rpx;
  font-size: 24rpx;
  color: #1e40af;
  text-align: center;
  font-weight: 600;
}

.total-dose-display .highlight {
  color: #1d4ed8;
  font-size: 28rpx;
  font-family: Consolas, Monaco, monospace;
}

.result-list {
  margin-top: 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
  padding-top: 20rpx;
}

.result-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.row-label {
  color: #64748b;
  font-weight: 600;
}

.row-val {
  color: #0f172a;
}

.font-bold {
  font-weight: 700;
  color: #1d4ed8;
}

/* Warnings and info boxes */
.banner {
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-top: 24rpx;
}

.banner-title {
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.banner-desc {
  font-size: 22rpx;
  line-height: 1.4;
}

.banner-warning {
  background: #fffbeb;
  border: 1rpx solid rgba(217, 119, 6, 0.15);
  color: #b45309;
}

.banner-warning .banner-title {
  color: #d97706;
}

.banner-danger {
  background: #fef2f2;
  border: 1rpx solid rgba(220, 38, 38, 0.15);
  color: #b91c1c;
}

.banner-danger .banner-title {
  color: #dc2626;
}

.error-tip {
  font-size: 22rpx;
  color: #64748b;
  text-align: center;
  margin-top: 16rpx;
  line-height: 1.4;
}

/* Action button */
.copy-btn {
  margin-top: 30rpx;
  background: #0f172a;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  border-radius: 16rpx;
  padding: 20rpx 0;
  text-align: center;
  line-height: 1.5;
  box-shadow: 0 4rpx 14rpx rgba(15, 23, 42, 0.15);
}

.copy-btn::after {
  border: none;
}

/* Pending State display */
.pending-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.pending-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.pending-text {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 500;
}

/* Footer style */
.footer {
  text-align: center;
  font-size: 20rpx;
  color: #94a3b8;
  line-height: 1.4;
  margin-bottom: 20rpx;
}
