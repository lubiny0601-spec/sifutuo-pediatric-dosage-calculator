<!-- index.wxml -->
<view class="container">
  <!-- 头部 Header -->
  <view class="header animated-fade-in">
    <view class="title-container">
      <view class="main-title">注射用氨曲南阿维巴坦钠</view>
      <view class="badge-mini">剂量计算参考</view>
    </view>
    <view class="subtitle">静脉滴注剂量快速计算与安全参考辅助参考工具 (成人专用)</view>
  </view>

  <!-- 输入面板 Card -->
  <view class="card animated-fade-in stagger-1">
    <view class="card-header">
      <view class="card-title">剂量参数输入</view>
    </view>

    <!-- 静态药品显示 -->
    <view class="static-drug-info">
      <view class="label">查询药品</view>
      <view class="value">注射用氨曲南阿维巴坦钠 (2.0g)</view>
    </view>

    <!-- 第一步：体重输入 -->
    <view class="form-group">
      <view class="form-label-row">
        <text class="step-num">1</text>
        <text class="form-label">录入患者体重 (选填/辅助, kg)</text>
      </view>
      <input class="input-control" type="digit" placeholder="输入体重用于CG清除率计算 (例: 60)" value="{{weight}}" bindinput="onWeightInput" />
    </view>

    <!-- 第二步：肾功能选择 -->
    <view class="form-group">
      <view class="form-label-row">
        <text class="step-num">2</text>
        <text class="form-label">选择患者肾功能状态 (eCrCL)</text>
      </view>
      <picker mode="selector" range="{{renalOptions}}" range-key="text" value="{{renalIndex}}" bindchange="onRenalChange">
        <view class="picker-control">
          <text>{{renalOptions[renalIndex].text}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- Cockcroft-Gault 肾清除率计算器 -->
    <view class="cg-panel">
      <view class="cg-header" bindtap="toggleCgCollapse">
        <view class="cg-title">
          <text class="cg-icon">📊</text>
          <text>Cockcroft-Gault 肾清除率辅助计算器</text>
        </view>
        <text class="cg-toggle-indicator">{{cgCollapsed ? '展开 +' : '折叠 -'}}</text>
      </view>

      <view class="cg-body" wx:if="{{!cgCollapsed}}">
        <view class="cg-grid">
          <view class="cg-field">
            <view class="cg-label">年龄 (岁)</view>
            <input class="cg-input" type="number" placeholder="岁" value="{{cgAge}}" bindinput="onCgAgeInput" />
          </view>
          <view class="cg-field">
            <view class="cg-label">性别</view>
            <view class="cg-gender-toggle">
              <view class="gender-btn {{cgGender === 'male' ? 'active' : ''}}" bindtap="setCgGender" data-val="male">男</view>
              <view class="gender-btn {{cgGender === 'female' ? 'active' : ''}}" bindtap="setCgGender" data-val="female">女</view>
            </view>
          </view>
        </view>

        <view class="cg-grid" style="margin-top: 12px;">
          <view class="cg-field">
            <view class="cg-label">体重 (kg)</view>
            <input class="cg-input" type="digit" placeholder="kg" value="{{weight}}" bindinput="onWeightInput" />
          </view>
          <view class="cg-field">
            <view class="cg-label">血肌酐 (Scr)</view>
            <view class="scr-input-container">
              <input class="cg-input scr-input" type="digit" placeholder="数值" value="{{cgScr}}" bindinput="onCgScrInput" />
              <picker class="scr-unit-picker" mode="selector" range="{{scrUnits}}" value="{{scrUnitIndex}}" bindchange="onScrUnitChange">
                <view class="unit-picker-text">{{scrUnits[scrUnitIndex]}} ▾</view>
              </picker>
            </view>
          </view>
        </view>

        <view class="cg-result-bar" wx:if="{{cgResult !== null}}">
          估算 eCrCL 值为：<text class="cg-result-val">{{cgResult}}</text> mL/min
        </view>

        <button class="cg-calc-btn" bindtap="calculateAndApplyCg">计算并一键代入清除率</button>
      </view>
    </view>
  </view>

  <!-- 计算结果 Card -->
  <view class="card animated-fade-in stagger-2" style="margin-top: 16px; margin-bottom: 30px;">
    <view class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
      <view class="card-title">剂量计算结果</view>
      <view class="status-badge {{calcResult.success ? 'badge-success' : 'badge-error'}}" wx:if="{{calcResult}}">
        <text class="dot"></text>
        <text>{{calcResult.success ? '计算成功' : '禁止给药'}}</text>
      </view>
      <view class="status-badge badge-pending" wx:else>
        <text class="dot"></text>
        <text>待计算</text>
      </view>
    </view>

    <!-- 计算成功面板 -->
    <view wx:if="{{calcResult && calcResult.success}}">
      <view class="result-grid">
        <!-- 负荷剂量 -->
        <view class="result-cell-col">
          <view class="col-title">① 负荷剂量 (Loading)</view>
          <view class="cell-row">
            <text class="row-label">氨曲南：</text>
            <text class="row-val font-code">{{calcResult.data.loadAztreonamMg}}<text class="unit-lbl">mg</text></text>
          </view>
          <view class="cell-row">
            <text class="row-label">阿维巴坦：</text>
            <text class="row-val font-code">{{calcResult.data.loadAvibactamMg}}<text class="unit-lbl">mg</text></text>
          </view>
          <view class="draw-vol-box">
            需抽吸复溶溶液：<text class="val-bold">{{calcResult.data.drawVolumeLoadMl}}</text> mL
          </view>
        </view>

        <!-- 维持剂量 -->
        <view class="result-cell-col">
          <view class="col-title">② 维持剂量 (Maint)</view>
          <view class="cell-row">
            <text class="row-label">氨曲南：</text>
            <text class="row-val font-code">{{calcResult.data.maintAztreonamMg}}<text class="unit-lbl">mg</text></text>
          </view>
          <view class="cell-row">
            <text class="row-label">阿维巴坦：</text>
            <text class="row-val font-code">{{calcResult.data.maintAvibactamMg}}<text class="unit-lbl">mg</text></text>
          </view>
          <view class="draw-vol-box">
            需抽吸复溶溶液：<text class="val-bold">{{calcResult.data.drawVolumeMaintMl}}</text> mL
          </view>
        </view>
      </view>

      <view class="result-list">
        <view class="result-row">
          <text class="row-label">维持给药间隔：</text>
          <text class="row-val font-bold">{{calcResult.data.frequencyText}}</text>
        </view>
        <view class="result-row">
          <text class="row-label">静脉输注时间：</text>
          <text class="row-val">{{calcResult.data.duration}}</text>
        </view>
        <view class="result-row">
          <text class="row-label">剂量来源依据：</text>
          <text class="row-val text-muted" style="font-size: 11px;">{{calcResult.data.source}}</text>
        </view>
      </view>

      <!-- 临床配制备注 -->
      <view class="banner banner-warning" wx:if="{{calcResult.data.note}}">
        <view class="banner-title">⚠️ 临床配制与给药备注</view>
        <view class="banner-desc">{{calcResult.data.note}}</view>
      </view>

      <button class="copy-btn" bindtap="copyResults">复制计算结果 (供微信/病历粘贴)</button>
    </view>

    <!-- 禁止计算面板 -->
    <view wx:elif="{{calcResult && !calcResult.success}}">
      <view class="banner banner-danger" style="margin-top: 10px;">
        <view class="banner-title">🚫 剂量计算受阻</view>
        <view class="banner-desc">{{calcResult.error}}</view>
      </view>
      <view class="error-tip">
        请参考药品官方说明书或咨询临床医学团队进行人工评估。
      </view>
    </view>

    <!-- 待录入状态 -->
    <view class="pending-state" wx:else>
      <view class="pending-icon">✏️</view>
      <view class="pending-text">请在上方选择肾功能参数以开始计算</view>
    </view>
  </view>

  <!-- 页脚数据声明 -->
  <view class="footer">
    <view>声明：本工具仅供临床医护人员参考，具体决策须结合患者实际临床情况。</view>
    <view style="margin-top: 4px;">数据来源：注射用氨曲南阿维巴坦钠说明书</view>
  </view>
</view>
